# --- Lorin RAG Environment Configuration ---

# Interface
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Vector Database (Qdrant)
QDRANT_URL=https://your-qdrant-instance.aws.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# Database (Supabase / Postgres)
DATABASE_URL=postgres://postgres:password@db.supabase.co:5432/postgres

# LLM Providers (Rotating Keys for Rate Limits)
OPENAI_API_KEY=sk-your-openai-key
OPENROUTER_API_KEY=sk-or-your-openrouter-key

# Vercel Gateway Keys (Optional for Load Balancing)
VERCEL_AI_KEY=sk-key-1
VERCEL_AI_KEY_2=sk-key-2
VERCEL_AI_KEY_3=sk-key-3
VERCEL_AI_KEY_4=sk-key-4

# Links
GOOGLE_FORM_URL=https://forms.gle/your-admission-enquiry-form

# Security & Reporting
ADMIN_IDS=12345678,98765432
