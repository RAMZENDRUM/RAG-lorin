# --- 🤖 Lorin RAG: Env Template --- #

# 1. AI Models (OpenAI / Vercel Gateway)
OPENAI_API_KEY=your_openai_key_here
# Optional: Use Vercel AI Gateway for rotation
VERCEL_AI_KEY=your_vercel_key

# 2. Vector Databases
QDRANT_URL=your_qdrant_cloud_url
QDRANT_API_KEY=your_qdrant_api_key
DATABASE_URL=postgresql://user:pass@host:port/db?sslmode=require

# 3. Interfaces
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 4. Ingestion
FIRECRAWL_API_KEY=your_firecrawl_key

# 5. Fallbacks & Secondary Engines
COHERE_API_KEY=optional_cohere_key
GOOGLE_GENERATIVE_AI_API_KEY=optional_gemini_key
